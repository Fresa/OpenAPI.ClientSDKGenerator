<Project>

    <ItemGroup>
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="SourceItemGroup" />
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="ClientName" />
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="Namespace" />
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="OpenApiUri" />
    </ItemGroup>

    <Target Name="_ClientSDKGenerator_AddAdditionalFiles"
            BeforeTargets="PrepareForBuild;BeforeCompile;GenerateMSBuildEditorConfigFile;CoreCompile">
        <ItemGroup>
            <AdditionalFiles Include="%(ClientSDKGenerator.OpenApiUri)"
                             SourceItemGroup="ClientSDKGenerator"
                             ClientName="%(ClientSDKGenerator.Identity)"
                             OpenApiUri="%(ClientSDKGenerator.OpenApiUri)"
                             Namespace="%(ClientSDKGenerator.Namespace)" />
        </ItemGroup>
    </Target>

</Project>
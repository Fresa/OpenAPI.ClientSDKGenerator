          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["placed", "approved", "delivered"],
          "default": "placed"
        },
        "complete": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "User": {
      "type": "object",
      "required": ["username", "email"],
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64",
          "readOnly": true
        },
        "username": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "pattern": "^[a-zA-Z0-9_]+$"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "password": {
          "type": "string",
          "format": "password"
        },
        "phone": {
          "type": "string"
        },
        "userStatus": {
          "type": "integer",
